#include "highmap.hpp"

int main(void)
{
  hmap::gpu::init_opencl();

  glm::ivec2   shape = {256, 256};
  glm::vec2 kw = {4.f, 4.f};
  uint              seed = 0;

  hmap::Array z1 = hmap::gpu::plates(shape, kw, seed, 2.f / shape.x);

  hmap::export_banner_png("ex_plates.png", {z1}, hmap::Cmap::TERRAIN, true);
}
